generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model GrowthEntry {
  id        String   @id @default(cuid())
  title     String
  content   String
  category  String
  date      DateTime @default(now())
  tags      String[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([date])
  @@index([category])
}

model Skill {
  id          String   @id @default(cuid())
  name        String   @unique
  category    String
  level       Int      @default(1)
  description String?
  learnedAt   DateTime @default(now())
  tags        String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@index([level])
}

model Project {
  id          String    @id @default(cuid())
  title       String
  description String
  status      String    @default("planning")
  techStack   String[]
  githubUrl   String?
  demoUrl     String?
  progress    Int       @default(0)
  priority    String
  category    String
  startedAt   DateTime  @default(now())
  completedAt DateTime?
  endDate     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status])
  @@index([category])
  @@index([startedAt])
}

model Task {
  id          String    @id @default(cuid())
  name        String
  description String
  type        String
  status      String
  progress    Int       @default(0)
  priority    String
  startedAt   DateTime?
  completedAt DateTime?
  plannedFor  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status])
  @@index([priority])
}

model DailyStats {
  id             String   @id @default(cuid())
  date           DateTime @unique
  focusTime      Int      @default(0)
  skillsUnlocked Int      @default(0)
  tasksCompleted Int      @default(0)
  tasksTotal     Int      @default(0)
  currentTask    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([date])
}
